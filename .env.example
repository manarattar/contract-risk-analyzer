# OpenAI-compatible API key (leave empty to run in mock mode)
OPENAI_API_KEY=

# API base URL — change for local models (e.g. Ollama: http://localhost:11434/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use
MODEL_NAME=gpt-4o-mini

# Force mock mode even if API key is set (true/false)
MOCK_MODE=false

# Allowed CORS origins (comma-separated, or * for all — default is *)
# In production, set to your frontend URL: https://your-frontend.onrender.com
CORS_ORIGINS=*
